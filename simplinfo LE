#!/bin/sh

user="${USER}"
HOST="$(hostname)"
if command -v lsb_release >/dev/null 2>&1; then
    DIS="$(lsb_release -sd)"
elif [ -f /etc/os-release ]; then
    . /etc/os-release
    DIS="$PRETTY_NAME"
else
    DIS="Unknown Linux"
fi
OS="$(uname -sr)"
DE="${XDG_CURRENT_DESKTOP}"
Shell="$(basename "$SHELL")"
CPU="$(lscpu | grep 'Model name' | sed 's/.*: *//')"
GPU="$(glxinfo -B | awk -F': ' '/Device:/ {print $2; exit}')"
RAM="$(free -h | awk '/^Mem:/ {print $3 "/" $2}')"
current_year="$(date +%Y)"
if [ -s "$HOME/.bestanime" ]; then
    Best_anime="$(cat "$HOME/.bestanime")"
else
    Best_anime="Ganbare Nakamura-kun!!"
fi

# COLORS
c1="\e[31m" # Red
c2="\e[32m" # Green
c3="\e[33m" # Yellow
c4="\e[34m" # Calm Blue
c5="\e[35m" # Violet
c6="\e[36m" # Arch Blue
c7="\e[37m" # White
c8="\e[90m" # Grey
c9="\e[91m" # Bright Red
c10="\e[92m" # Bright Green
c11="\e[93m" # Bright Yellow
c12="\e[94m" # Bright Blue
c13="\e[95m" # Bright Violet
c14="\e[96m" # Bright Arch Blue
c15="\e[97m" # Actual White
c16="\e[38;5;208m" # Orange
c20="\e[0m" # Normal
c21="\e[0;1m" # Bold

# An Error echo wrapper (prints to stderr and exits)
err0r() {
    # \033[1;31m = Bold Red, \033[0m = Reset
    printf '\033[1;31m[-] ERROR: %s\033[0m\n' "$1" >&2
    exit 86
}

# A Warning echo wrapper (prints to stderr)
warn() {
    # \033[1;33m = Bold Yellow, \033[0m = Reset
    printf '\033[1;33m[!] WARNING: %s\033[0m\n' "$1" >&2
}

# A Message echo wrapper (prints to stdout)
msg() {
    # \033[1;32m = Bold Green, \033[0m = Reset
    printf '\033[1;32m[+] %s\033[0m\n' "$1"
}

# The display

echo ""
echo -e "${c21}${user}@${HOST}${c20}"
echo
echo -e "${c1}     Distro:${c20} ${DIS}"
echo -e "${c16}     Kernel:${c20} ${OS}"
echo -e "${c11}     Desktop Environment:${c20} ${DE}"
echo -e "${c2}     Shell:${c20} ${Shell}"
echo -e "${c6}     CPU:${c20} ${CPU}"
echo -e "${c4}     GPU:${c20} ${GPU}"
echo -e "${c5}     RAM:${c20} ${RAM}"
echo -e "${c8}     The Best Anime:${c21} ${Best_anime}"
echo
echo
echo -e "${c20}     Simplinfo LE version 1.4        2026-${current_year}"
echo ""
